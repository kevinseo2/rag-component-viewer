# ─────────────────────────────────────────────────────────────
# ChromaDB Configuration
# Production: centralized server (10.177.121.107)
# Development: localhost for local testing
# ─────────────────────────────────────────────────────────────
CHROMA_BASE_URL=http://10.177.121.107:8000
# CHROMA_BASE_URL=http://localhost:8000

# NEXT_PUBLIC_ prefix makes this available in the browser (shown in Explorer footer)
NEXT_PUBLIC_CHROMA_BASE_URL=10.177.121.107:8000
# NEXT_PUBLIC_CHROMA_BASE_URL=localhost:8000

# ChromaDB collection names
CHROMA_DESCRIPTION_COLLECTION=ui_components_description
CHROMA_CODE_COLLECTION=ui_components_code
CHROMA_SAMPLES_COLLECTION=ui_components_samples

# ─────────────────────────────────────────────────────────────
# Ollama / Embedding Configuration
# ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://10.177.121.107:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (must be available on the Ollama server)
EMBEDDING_MODEL=bge-m3
